# Traefik Environment Variables

# Base path for persistent application data
APPDATA_PATH=/home/kyle/appdata

# Traefik dashboard hostname
HOSTNAME=traefik.example.com

# Domain configuration for Let's Encrypt certificates
DOMAIN_MAIN=example.com
DOMAIN_SANS=*.example.com

# Cloudflare DNS API token (alternative to Docker secret)
# CF_DNS_API_TOKEN=your_cloudflare_api_token
