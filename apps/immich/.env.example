# Immich Environment Variables

# Immich version (default: release)
IMMICH_VERSION=release

# Upload location on host
UPLOAD_LOCATION=/path/to/immich/uploads

# Database configuration
DB_PASSWORD=your_db_password
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
DB_DATA_LOCATION=/path/to/postgres/data

# Traefik hostname (used by power-tools)
HOSTNAME=immich-tools.example.com
