# AssetFlow Environment Variables

# Base path for persistent application data
APPDATA_PATH=/home/kyle/appdata

# TMDB API key for fetching artwork
TMDB_API_KEY=your_tmdb_api_key

# TVDB API credentials
TVDB_API_KEY=your_tvdb_api_key
TVDB_PIN=your_tvdb_pin

# Plex server connection
PLEX_BASE_URL=http://your-plex-server:32400
PLEX_TOKEN=your_plex_token

# Traefik hostname
HOSTNAME=assetflow.example.com
