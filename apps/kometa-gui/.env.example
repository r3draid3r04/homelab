# Kometa GUI Environment Variables

# Base path for persistent application data
APPDATA_PATH=/home/kyle/appdata

# Application settings
NODE_ENV=development
PORT=3001
CONFIG_DIR=/config
LOGS_DIR=/logs
LOG_LEVEL=info

# Kometa Docker container name to manage
KOMETA_CONTAINER_NAME=kometa

# Frontend URLs
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Mediux integration
MEDIUX_API_URL=https://staged.mediux.io/graphql
MEDIUX_API_TOKEN=your_mediux_api_token
MEDIUX_ASSET_URL=https://staged.mediux.io/assets
MEDIUX_CACHE_DIR=/cache/mediux
MEDIUX_SYNC_INTERVAL=0 0 * * *

# Database
DATABASE_URL=file:/data/dev.db
