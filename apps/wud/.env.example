# What's Up Docker Environment Variables

# MQTT broker connection for Home Assistant
MQTT_BROKER_URL=mqtt://your-mqtt-broker:1883
MQTT_BROKER_USER=your_mqtt_user
MQTT_BROKER_PASSWORD=your_mqtt_password

# Private Docker registry credentials
WUD_REGISTRY_URL=https://registry.example.com
WUD_REGISTRY_USER=your_registry_user
WUD_REGISTRY_PASSWORD=your_registry_password
